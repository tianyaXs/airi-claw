# =============================================================================
# OpenClaw Gateway 配置
# =============================================================================

# WebSocket 服务地址
# 默认: ws://127.0.0.1:18789
VITE_OPENCLAW_URL=ws://127.0.0.1:18789

# 认证 Token（必需）
# 获取方式：
# 1. 通过 CLI 命令查看: openclaw config get gateway.auth.token
# 2. 查看配置文件: cat ~/.openclaw/openclaw.json
# 3. 查看环境变量: echo $OPENCLAW_GATEWAY_TOKEN
# 4. 生成新 Token: openclaw doctor --generate-gateway-token
#
# Token 存储位置优先级：
# 1. 环境变量 OPENCLAW_GATEWAY_TOKEN
# 2. 配置文件 ~/.openclaw/openclaw.json -> gateway.auth.token
#
VITE_OPENCLAW_TOKEN=your_token_here

# Agent ID（可选）
# 用于指定对话的 AI 角色或预设配置
# 默认: main
# 说明：不同的 Agent 可以配置不同的模型、系统提示词等
VITE_OPENCLAW_AGENT=main

# 系统提示词（可选）
# 用于自定义 AI 的行为和回复风格
# 会在每次对话时作为额外的系统提示词发送给 AI
# 示例：VITE_OPENCLAW_SYSTEM_PROMPT="你是一个可爱的虚拟助手，请用可爱的语气回答"
VITE_OPENCLAW_SYSTEM_PROMPT=

# 思考级别（可选）
# 控制 AI 的推理深度和详细程度
# 可选值: off, minimal, low, medium, high, xhigh
# 默认: xhigh（最高级别，最详细的推理）
VITE_OPENCLAW_THINKING=xhigh

# =============================================================================
# 关于 VITE_ 前缀的说明
# =============================================================================
# 
# 这是 Vite 构建工具的安全机制：
# - 只有以 VITE_ 开头的环境变量才会暴露给客户端代码
# - 防止敏感的服务端配置意外泄露到前端
# - 代码中使用：const token = import.meta.env.VITE_OPENCLAW_TOKEN
#
# 不以 VITE_ 开头的变量只能在 Node.js 服务端访问
