{
  "compilerOptions": {
    "target": "ESNext", "module": "ESNext", "moduleResolution": "bundler",
    "strict": true, "jsx": "preserve", "sourceMap": true,
    "resolveJsonModule": true, "isolatedModules": true,
    "esModuleInterop": true, "lib": ["ESNext", "DOM"],
    "skipLibCheck": true, "noEmit": true,
    "baseUrl": ".", "paths": { "@/*": ["src/renderer/*"] }
  },
  "include": ["src/**/*", "index.html", "electron.vite.config.ts"]
}
